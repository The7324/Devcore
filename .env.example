# ── DevCore Environment Configuration ─────────────────────────────
# Copy this file to .env or configure as Cloudflare Workers secrets.
#   cp .env.example .env
#
# For Cloudflare Workers: set each value via `wrangler secret put <KEY>`
# or define in wrangler.toml [vars] section for non-sensitive values.
#
# Required variables are marked with (REQUIRED).

# ── Telegram ──────────────────────────────────────────────────────

# Telegram Bot API token from @BotFather (REQUIRED)
# Generate at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional webhook secret for additional security
# TELEGRAM_WEBHOOK_SECRET=

# ── Authorization ─────────────────────────────────────────────────

# Telegram user ID of the bot owner (REQUIRED)
# Has full access to all commands and can manage admins.
# Find your ID: message @userinfobot on Telegram
OWNER_ID=123456789

# Comma-separated list of additional admin Telegram user IDs
# These users have admin-level permissions (see SECURITY.md).
# ADMIN_IDS=987654321,555555555

# ── Encryption ────────────────────────────────────────────────────

# AES-256 encryption key for securing stored credentials.
# If not set, credentials will NOT be encrypted (not recommended for production).
# Generate: openssl rand -hex 32
# ENCRYPTION_KEY=your_64_char_hex_key

# ── Runtime ────────────────────────────────────────────────────────

# Runtime environment: development, production, or staging
# ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARN, ERROR
# LOG_LEVEL=INFO

# ── Rate Limiting ─────────────────────────────────────────────────

# Maximum requests per rate-limit window per user
# RATE_LIMIT_MAX=30

# Rate-limit window in seconds
# RATE_LIMIT_WINDOW_SEC=60

# ── Sessions ──────────────────────────────────────────────────────

# Session time-to-live in seconds (how long auth sessions last)
# SESSION_TTL_SEC=3600
