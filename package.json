{
  "name": "devcore",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram-based DevOps platform foundation",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply devcore-db",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.20",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10",
    "wrangler": "^3.109.0"
  }
}
